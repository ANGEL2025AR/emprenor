# Copiar a .env.local en desarrollo; en Vercel: Project → Settings → Environment Variables

# URL canónica del sitio (metadatos, SEO, enlaces absolutos)
NEXT_PUBLIC_SITE_URL=https://www.emprenor.com

# MongoDB Atlas — requerido para dashboard, APIs y CMS
MONGODB_URI=

# Firma de sesiones JWT — usar un secreto largo y aleatorio en producción
JWT_SECRET=

# Vercel Blob — subida de imágenes, documentos de obra y legajo de empleados
BLOB_READ_WRITE_TOKEN=

# Opcional: base para Server Components que llaman a /api del mismo despliegue
# En local suele bastar el default http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Opcional: Google Search Console (solo el valor del meta verification)
# GOOGLE_SITE_VERIFICATION=

# Obligatorio en producción: clave para /setup (primer super_admin)
# ADMIN_SETUP_KEY=

# Registro público en /registro — consultas, cotizaciones y alta de clientes
# ALLOW_PUBLIC_REGISTRATION=true

# --- Notificaciones de contacto (formulario /contacto) ---
# Si RESEND_API_KEY y CONTACT_NOTIFY_EMAIL están definidos, cada lead envía email vía Resend.
# Crear cuenta en https://resend.com → API Keys → verificar dominio emprenor.com.ar
RESEND_API_KEY=
CONTACT_NOTIFY_EMAIL=info@emprenor.com.ar
# Remitente (dominio verificado en Resend). Sin verificar, Resend solo envía a tu email de prueba.
CONTACT_FROM_EMAIL=EMPRENOR <contacto@emprenor.com.ar>
# Alternativa o complemento: webhook JSON (Slack, Make, n8n, etc.)
# CONTACT_NOTIFY_WEBHOOK_URL=

# Opcional: redes sociales (footer). Si no se define, se usan URLs por defecto.
# NEXT_PUBLIC_SOCIAL_FACEBOOK=https://www.facebook.com/emprenor
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/emprenor
# NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/company/emprenor

# CUIT titular legal — Silvio Carlos Fabian Guerrero (default en código: 20-40154622-8)
# NEXT_PUBLIC_EMPRENOR_CUIT=20-40154622-8
