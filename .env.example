# Copiar a .env.local en desarrollo; en Vercel: Project → Settings → Environment Variables

# URL canónica del sitio (build y metadatos)
NEXT_PUBLIC_SITE_URL=https://www.emprenor.com

# MongoDB (Atlas) — requerido para dashboard, proyectos públicos y CMS de portadas
MONGODB_URI=

# Firma de sesiones JWT — en producción usá un secreto largo y aleatorio
JWT_SECRET=

# Vercel Blob — subida de imágenes de proyectos públicos y documentos
BLOB_READ_WRITE_TOKEN=

# Opcional: Google Search Console (valor del meta verification, sin la etiqueta HTML)
# GOOGLE_SITE_VERIFICATION=

# Opcional: base para fetch desde Server Components a tu propia API (por defecto localhost en dev)
# NEXT_PUBLIC_APP_URL=https://www.emprenor.com
